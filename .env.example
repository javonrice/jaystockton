# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# In GitHub Codespaces you can also set these as repository secrets
# at Settings → Secrets and variables → Codespaces — they inject
# automatically as environment variables when the container starts.

# Alpaca Markets API (free account at alpaca.markets)
# Paper trading keys work for real-time data and are safer to start with.
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Data feed: "iex" (free, ~15 min delayed) or "sip" (paid, real-time)
ALPACA_FEED=iex

# DuckDB database file path (relative to repo root)
DB_PATH=signal_brain.duckdb

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Number of bars to fetch when market is closed (fallback mode).
# 390 = one full trading day of minute bars. Set to 5 during development
# to speed up the initial seed when testing outside market hours.
BARS_FALLBACK_LIMIT=390
